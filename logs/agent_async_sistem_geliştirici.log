.mark_processing(url, self.db_lock)\n                    await self.memory_queue.put((url, depth))\n            \n            await asyncio.sleep(0.1)\n\n    async def start(self, seed_url: str, max_depth: int):\n        self._running = True\n        await self.db.add_to_queue([seed_url], 0, self.db_lock)\n        \n        connector = aiohttp.TCPConnector(limit=self.worker_count)\n        async with aiohttp.ClientSession(connector=connector) as session:\n            workers = [asyncio.create_task(self._worker(session)) for _ in range(self.worker_count)]\n            indexer = asyncio.create_task(self._run_index_job(max_depth))\n            await asyncio.gather(*workers, indexer)\n\n    def start_in_background(self, seed_url: str, max_depth: int):\n        def _run():\n            asyncio.run(self.start(seed_url, max_depth))\n        threading.Thread(target=_run, daemon=True).start()\n\n    def resume_in_background(self, max_depth: int):\n        self._running = True\n        def _run():\n            asyncio.run(self._run_index_job(max_depth))\n        threading.Thread(target=_run, daemon=True).start()\n```', text='```python\nimport asyncio\nimport aiohttp\nimport logging\nimport threading\nfrom datetime import datetime\nfrom html.parser import HTMLParser\nfrom urllib.parse import urljoin\nfrom database import Database\n\n# Loglama yapılandırması\nlogger = logging.getLogger("CrawlerService")\n\nclass MiniParser(HTMLParser):\n    def __init__(self, base_url: str):\n        super().__init__()\n        self.base_url = base_url\n        self.links = set()\n        self.content = []\n        self.title = ""\n        self._skip = False\n        self._in_title = False\n\n    def handle_starttag(self, tag, attrs):\n        if tag in (\'script\', \'style\', \'head\'):\n            self._skip = True\n        if tag == \'title\':\n            self._in_title = True\n        if tag == \'a\':\n            for attr, value in attrs:\n                if attr == \'href\':\n          