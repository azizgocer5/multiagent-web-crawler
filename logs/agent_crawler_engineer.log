lientSession(connector=connector) as session:\n            workers = [asyncio.create_task(self._worker(session)) for _ in range(self.worker_count)]\n            indexer = asyncio.create_task(self._run_index_job(max_depth))\n            await asyncio.gather(*workers, indexer)\n\n    def start_in_background(self, seed_url: str, max_depth: int) -> None:\n        self.stop()\n        task = asyncio.create_task(self._engine(seed_url, max_depth))\n        self._tasks.add(task)\n\n    def resume_in_background(self, max_depth: int) -> None:\n        self.stop()\n        task = asyncio.create_task(self._engine(None, max_depth))\n        self._tasks.add(task)\n\n    def stop(self) -> None:\n        self._running = False\n        for task in self._tasks:\n            task.cancel()\n        self._tasks.clear()\n```', text='FILE: crawler_service.py\n```python\nimport asyncio\nimport aiohttp\nimport logging\nfrom html.parser import HTMLParser\nfrom urllib.parse import urljoin\nfrom database import Database\n\nlogger = logging.getLogger("CrawlerService")\n\nclass MiniParser(HTMLParser):\n    def __init__(self, base_url: str):\n        super().__init__()\n        self.base_url = base_url\n        self.links = set()\n        self.content = []\n        self.title = ""\n        self._skip = False\n        self._in_title = False\n        self._title_found = False\n\n    def handle_starttag(self, tag, attrs):\n        if tag in (\'script\', \'style\', \'head\'):\n            self._skip = True\n        if tag == \'title\':\n            self._in_title = True\n        if tag == \'a\':\n            for attr, value in attrs:\n                if attr == \'href\':\n                    full_url = urljoin(self.base_url, value).split(\'#\')[0]\n                    if full_url.startswith((\'http://\', \'https://\')):\n                        self.links.add(full_url)\n\n    def handle_endtag(self, tag):\n        if tag in (\'script\', \'style\', \'head\'):\n            self._skip = False\n        i