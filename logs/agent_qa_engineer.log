ound(depth)\n                console.print(f"Started crawling: {url}")\n\n            elif cmd == "search":\n                query = " ".join(parts[1:])\n                results = await db.search(query)\n                if not results:\n                    console.print("No results found.")\n                else:\n                    table = Table(title=f"Results for \'{query}\'", ascii_only=True)\n                    table.add_column("Depth")\n                    table.add_column("URL")\n                    table.add_column("Origin")\n                    table.add_column("Title")\n                    for r in results:\n                        table.add_row(str(r.get(\'depth\', \'\')), r.get(\'url\', \'\'), r.get(\'origin_url\', \'\'), (r.get(\'title\') or "")[:30])\n                    console.print(table)\n\n            elif cmd == "status":\n                status = await db.get_status()\n                console.print(f"Status: {status} | Active Tasks: {len(service._background_tasks)}")\n\n            elif cmd == "resume":\n                max_depth_str = await db.get_setting(\'max_depth\')\n                depth = int(max_depth_str) if max_depth_str else 2\n                await db.resume_processing()\n                service.start_in_background(depth)\n                console.print(f"Resumed crawling (depth={depth}).")\n\n            elif cmd == "exit":\n                service.stop()\n                if service._background_tasks:\n                    await asyncio.gather(*service._background_tasks, return_exceptions=True)\n                break\n            else:\n                console.print("Unknown command.")\n        except Exception as e:\n            console.print(f"Error: {e}")\n\n    await db.close()\n    console.print("Shutdown complete.")\n\nif __name__ == "__main__":\n    try:\n        asyncio.run(main())\n    except KeyboardInterrupt:\n        sys.exit(0)\n```')
