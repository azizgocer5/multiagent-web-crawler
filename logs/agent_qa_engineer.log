   content TEXT\n                    )\n                """)\n                await db.commit()\n\n    async def add_page(self, url, title, depth, content):\n        async with self.lock:\n            async with aiosqlite.connect(self.db_path) as db:\n                await db.execute(\n                    "INSERT OR IGNORE INTO pages (url, title, depth, content) VALUES (?, ?, ?, ?)",\n                    (url, title, depth, content)\n                )\n                await db.commit()\n\n    async def search(self, query):\n        async with self.lock:\n            async with aiosqlite.connect(self.db_path) as db:\n                db.row_factory = aiosqlite.Row\n                cursor = await db.execute(\n                    "SELECT url, title, depth FROM pages WHERE content LIKE ? OR title LIKE ?",\n                    (f"%{query}%", f"%{query}%")\n                )\n                return [dict(row) for row in await cursor.fetchall()]\n\n    async def get_stats(self):\n        async with self.lock:\n            async with aiosqlite.connect(self.db_path) as db:\n                cursor = await db.execute("SELECT COUNT(*) FROM pages")\n                count = (await cursor.fetchone())[0]\n                return {"done": count, "pending": 0, "processing": 0}\n\n    async def close(self):\n        pass\n```\n\nFILE: crawler_service.py\n```python\nimport asyncio\nimport aiohttp\nfrom bs4 import BeautifulSoup\nfrom urllib.parse import urljoin\n\nclass CrawlerService:\n    def __init__(self, db, max_workers=5):\n        self.db = db\n        self.max_workers = max_workers\n        self.queue = asyncio.Queue(maxsize=100)\n        self.visited = set()\n        self._background_tasks = set()\n        self._running = False\n\n    def start_in_background(self, start_url, max_depth):\n        self._running = True\n        task = asyncio.create_task(self._worker(start_url, max_depth))\n        self._background_tasks.add(task)\n        task.add_done_callback(self._background_tasks.discard)\n\n    async def _worker(self, start_url, max_depth):\n        await self.queue.put((start_url, 0))\n        async with aiohttp.ClientSession() as session:\n            while self._running and not self.queue.empty():\n                url, depth = await self.queue.get()\n                if url in self.visited or depth > max_depth:\n                    self.queue.task_done()\n                    continue\n                \n                self.visited.add(url)\n                try:\n                    async with session.get(url, timeout=10) as resp:\n                        html = await resp.text()\n                        soup = BeautifulSoup(html, \'html.parser\')\n                        title = soup.title.string if soup.title else "No Title"\n                        await self.db.add_page(url, title, depth, html)\n                        \n                        if depth < max_depth:\n                            for link in soup.find_all(\'a\', href=True):\n                                full_url = urljoin(url, link[\'href\'])\n                                if full_url not in self.visited:\n                                    await self.queue.put((full_url, depth + 1))\n                except Exception:\n                    pass\n                finally:\n                    self.queue.task_done()\n\n    def stop(self):\n        self._running = False\n```\n\nFILE: main.py\n```python\nimport asyncio\nfrom database import Database\nfrom crawler_service import CrawlerService\n\nasync def main():\n    db = Database(\'crawler.db\')\n    await db.init()\n    crawler = CrawlerService(db)\n\n    print("Mini Search Engine CLI")\n    print("Commands: crawl <url> <depth>, search <query>, status, exit")\n\n    while True:\n        cmd_input = await asyncio.get_event_loop().run_in_executor(None, input, \'> \')\n        parts = cmd_input.split()\n        if not parts: continue\n        \n        cmd = parts[0].lower()\n        if cmd == \'exit\':\n            c