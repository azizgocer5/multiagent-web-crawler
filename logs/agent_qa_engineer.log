db_path) as db:\n            async with db.execute(\n                "SELECT depth, url, \'origin\', title FROM pages WHERE title LIKE ? OR content LIKE ?",\n                (f\'%{query}%\', f\'%{query}%\')\n            ) as cursor:\n                return await cursor.fetchall()\n\n    async def close(self):\n        pass\n```\n\nFILE: crawler_service.py\n```python\nimport asyncio\nimport aiohttp\nimport aiosqlite\nfrom bs4 import BeautifulSoup\n\nclass CrawlerService:\n    def __init__(self, db):\n        self.db = db\n        self.db_lock = asyncio.Lock()\n        self._background_tasks = set()\n        self._semaphore = asyncio.Semaphore(5)\n        self.visited = set()\n\n    def start_in_background(self, url, depth):\n        task = asyncio.create_task(self._crawl_worker(url, depth))\n        self._background_tasks.add(task)\n        task.add_done_callback(self._background_tasks.discard)\n\n    def resume_in_background(self, max_depth):\n        pass\n\n    def stop(self):\n        for task in self._background_tasks:\n            task.cancel()\n\n    async def _crawl_worker(self, url, depth):\n        if url in self.visited or depth < 0:\n            return\n        self.visited.add(url)\n        \n        async with self._semaphore:\n            async with aiohttp.ClientSession() as session:\n                try:\n                    async with session.get(url, timeout=10) as response:\n                        html = await response.text()\n                        soup = BeautifulSoup(html, \'html.parser\')\n                        title = soup.title.string if soup.title else "No Title"\n                        \n                        async with self.db_lock:\n                            async with aiosqlite.connect(self.db.db_path) as db:\n                                await db.execute("INSERT OR REPLACE INTO pages VALUES (?, ?, ?, ?)", \n                                               (url, depth, title, html))\n                                await db.execute("INSERT OR REPLACE INTO queue (url, depth, status) VALUES (?, ?, \'done\')", (url, depth))\n                                await db.commit()\n                except Exception as e:\n                    print(f"Error crawling {url}: {e}")\n```\n\nFILE: main.py\n```python\nimport asyncio\nimport sys\nfrom database import Database\nfrom crawler_service import CrawlerService\n\nasync def main():\n    db = Database(\'crawler.db\')\n    await db.init_db()\n    crawler = CrawlerService(db)\n\n    print("Mini Search Engine CLI. Commands: crawl <url> <depth>, search <query>, status, resume, exit")\n\n    try:\n        while True:\n            cmd_line = await asyncio.to_thread(input, \'> \')\n            parts = cmd_line.strip().split()\n            if not parts:\n                continue\n            \n            cmd = parts[0].lower()\n\n            if cmd == \'crawl\' and len(parts) >= 3:\n                url, depth = parts[1], int(parts[2])\n                await db.add_to_queue([url], depth, crawler.db_lock)\n                crawler.start_in_background(url, depth)\n                print(f"Started crawling {url} at depth {depth}")\n\n            elif cmd == \'search\' and len(parts) >= 2:\n                query = " ".join(parts[1:])\n                results = await db.search(query)\n                if not results:\n                    print("No results found.")\n                else:\n                    for depth, url, origin, title in results:\n                        print(f"[{depth}] {title} | {url}")\n\n            elif cmd == \'status\':\n                pending = await db.count_pending()\n                processing = await db.count_processing()\n                done = await db.count_done()\n                print(f"Pending: {pending}, Processing: {processing}, Done: {done}")\n                print(f"Active background tasks: {len(crawler._background_tasks)}")\n\n            elif cmd == \'resume\':\n                max_depth = await db.get_max_depth()\n                await db.reset_processing_to_pending()\n                crawler.resume_in_background(max_depth)\n                print("Resuming crawl...")\n\n            elif cmd == \'exit\':\n                crawler.stop()\n                await db.close()\n                break\n            else:\n                print("Unknown command or missing arguments.")\n    except (EOFError, KeyboardInterrupt):\n        crawler.stop()\n        await db.close()\n\nif __name__ == "__main__":\n    asyncio.run(main())\n```')
