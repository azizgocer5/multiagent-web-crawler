) -> List[dict]:\n        def _sync():\n            sql = "SELECT url, title, depth, origin_url FROM pages WHERE title LIKE ? OR body LIKE ?"\n            q = f"%{query}%"\n            rows = self._conn.execute(sql, (q, q)).fetchall()\n            return [dict(r) for r in rows]\n        return await asyncio.to_thread(_sync)\n\n    async def get_setting(self, key: str) -> Optional[str]:\n        def _sync():\n            row = self._conn.execute("SELECT value FROM settings WHERE key = ?", (key,)).fetchone()\n            return row[\'value\'] if row else None\n        return await asyncio.to_thread(_sync)\n\n    async def set_setting(self, key: str, value: str) -> None:\n        async with self._lock:\n            await asyncio.to_thread(lambda: self._conn.execute("INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)", (key, value)))\n            self._conn.commit()\n\n    async def close(self) -> None:\n        await asyncio.to_thread(self._conn.close)\n```\n\nFILE: main.py\n```python\nimport asyncio\nimport sys\nfrom database import Database\nfrom crawler_service import CrawlerService\nfrom rich.console import Console\nfrom rich.table import Table\n\nconsole = Console(force_terminal=True, ascii_only=True)\n\nasync def main():\n    db = Database(\'crawler.db\')\n    service = CrawlerService(db)\n\n    console.print("[bold]Mini Search Engine CLI[/bold]")\n    console.print("Commands: crawl <url> <depth>, search <query>, status, resume, exit")\n\n    while True:\n        try:\n            cmd_input = await asyncio.to_thread(input, "> ")\n            parts = cmd_input.strip().split()\n            if not parts: continue\n            cmd = parts[0].lower()\n\n            if cmd == "crawl":\n                if len(parts) < 3:\n                    console.print("Usage: crawl <url> <depth>")\n                    continue\n                url, depth = parts[1], int(parts[2])\n                await db.set_setting(\'max_depth\', str(depth))\n                await db.add_to_queue([url], 0)\n                service.start_in_background(depth)\n                console.print(f"Started crawling: {url}")\n\n            elif cmd == "search":\n                query = " ".join(parts[1:])\n                results = await db.search(query)\n                if not results:\n                    console.print("No results found.")\n                else:\n                    table = Table(title=f"Results for \'{query}\'", ascii_only=True)\n                    table.add_column("Depth")\n                    table.add_column("URL")\n                    table.add_column("Origin")\n                    table.add_column("Title")\n                    for r in results:\n                        table.add_row(str(r.get(\'depth\', \'\')), r.get(\'url\', \'\'), r.get(\'origin_url\', \'\'), (r.get(\'title\') or "")[:30])\n                    console.print(table)\n\n            elif cmd == "status":\n                status = await db.get_status()\n                console.print(f"Status: {status} | Active Tasks: {len(service._background_tasks)}")\n\n            elif cmd == "resume":\n                max_depth_str = await db.get_setting(\'max_depth\')\n                depth = int(max_depth_str) if max_depth_str else 2\n                await db.resume_processing()\n                service.start_in_background(depth)\n                console.print(f"Resumed crawling (depth={depth}).")\n\n            elif cmd == "exit":\n                service.stop()\n                if service._background_tasks:\n                    await asyncio.gather(*service._background_tasks, return_exceptions=True)\n                break\n            else:\n                console.print("Unknown command.")\n        except Exception as e:\n            console.print(f"Error: {e}")\n\n    await db.close()\n    console.print("Shutdown complete.")\n\nif __name__ == "__main__":\n    try:\n        asyncio.run(main())\n    except KeyboardInterrupt:\n        sys.exit(0)\n```', text='FILE: qa_report.md\n```text\n# QA Audit Report\n\n## Checklist\n- [x] WAL mode active: Verified in database.py.\n- [x] Single event loop: No threading.Thread used.\n- [x] Bounded queue: CrawlerService uses asyncio.Queue(maxsize=100).\n- [x] Duplicate prevention: SQLite PRIMARY KEY + INSERT OR IGNORE used.\n- [x] Search during crawl: Non-blocking DB access via asyncio.to_thread.\n- [x] ASCII-safe: Rich console configured with ascii_only=True.\n\n## Bug List\n1. API Contract Error: The previous iteration referenced a non-existent `Database.force_pending` method in the CLI logic. This has been corrected to use `resume_processing`.\n2. Crawler Logic: The `_engine` method in `crawler_service.py` was redundantly adding the seed URL to the database. This has been moved to the CLI layer to ensure clean separation of concerns.\n3. State Management: `_indexer` now correctly handles state transitions to prevent race conditions where a URL might be picked up by multiple workers.\n\n## Acceptance Criteria\n- Syntax: Valid Python 3.11+ async code.\n- Crawl Progress: Status command reflects queue state.\n- Duplicate Prevention: Primary key constraints prevent URL collisions.\n- Search: Returns results while crawler is active.\n```\n\nFILE: crawler_service.py\n```python\nimport asyncio\nimport aiohttp\nfrom html.parser import HTMLParser\nfrom urllib.parse import urljoin\nfrom database import Database\n\nclass MiniParser(HTMLParser):\n    def __init__(self, base_url: str):\n        super().__init__()\n        self.base_url = base_url\n        self.links = set()\n        self.content = []\n        self.title = ""\n        self._skip = False\n        self._in_title = False\n\n    def handle_starttag(self, tag, attrs):\n        if tag in (\'script\', \'style\', \'head\'): self._skip = True\n        if tag == \'title\': self._in_title = True\n        if tag == \'a\':\n            for attr, value in attrs:\n                if attr == \'href\':\n                    full_url = urljoin(self.base_url, value)\n                    if full_url.startswith((\'http://\', \'https://\')): self.links.add(full_url)\n\n    def handle_endtag(self, tag):\n        if tag in (\'script\', \'style\', \'head\'): self._skip = False\n        if tag == \'title\': self._in_title = False\n\n    def handle_data(self, data):\n        if not self._skip: self.content.append(data.strip())\n        if self._in_title: self.title = data.strip()\n\nclass CrawlerService:\n    def __init__(self, db: Database, worker_count: int = 5):\n        self.db = db\n        self.worker_count = worker_count\n        self.memory_queue = asyncio.Queue(maxsize=100)\n        self._running = False\n        self._background_tasks = set()\n\n    async def _worker(self, session: aiohttp.ClientSession):\n        while self._running:\n            try:\n                url, depth = await self.memory_queue.get()\n            except asyncio.CancelledError:\n                break\n            try:\n                async with session.get(url, timeout=aiohttp.ClientTimeout(total=5)) as response:\n                    if \'text/html\' in response.headers.get(\'Content-Type\', \'\'):\n                        html = await response.text()\n                        parser = MiniParser(url)\n                        parser.feed(html)\n                        await self.db.save_page(url, parser.title, " ".join(parser.content), url, depth)\n                        await self.db.add_to_queue(list(parser.links), depth + 1)\n            except Exception:\n                pass\n            finally:\n                await self.db.mark_done(url)\n                self.memory_queue.task_done()\n\n    async def _indexer(self, max_depth: int):\n        while self._running:\n            if self.memory_queue.qsize() < 20:\n                pending = await self.db.get_pending(limit=10)\n                for url, depth in pending:\n                    if depth <= max_depth:\n                        await self.db.mark_processing(url)\n                        await self.memory_queue.put((url, depth))\n                    else:\n                        await self.db.mark_done(url)\n            await asyncio.sleep(1)\n\n    async def _engine(self, max_depth: int):\n        self._running = True\n        async with aiohttp.ClientSession() as session:\n            tasks = [asyncio.create_task(self._indexer(max_depth))]\n            tasks += [asyncio.create_task(self._worker(session)) for _ in range(self.worker_count)]\n            await asyncio.gather(*tasks)\n\n    def start_in_background(self, max_depth: int):\n        task = asyncio.create_task(self._engine(max_depth))\n        self._background_tasks.add(task)\n\n    def stop(self):\n        self._running = False\n        for t in self._background_tasks: t.cancel()\n```\n\nFILE: database.py\n```python\nimport sqlite3\nimport asyncio\nfrom typing import List, Tuple, Dict, Optional\n\nclass Database:\n    def __init__(self, db_path: str) -> None:\n        self.db_path = db_path\n        self._conn = sqlite3.connect(self.db_path, check_same_thread=False)\n        self._conn.row_factory = sqlite3.Row\n        self._conn.execute("PRAGMA journal_mode=WAL")\n        self._conn.execute("PRAGMA synchronous=NORMAL")\n        self._lock = asyncio.Lock()\n        self._create_tables()\n\n    def _create_tables(self) -> None:\n        with self._conn:\n            self._conn.execute("CREATE TABLE IF NOT EXISTS queue (url TEXT PRIMARY KEY, depth INTEGER, state TEXT DEFAULT \'pending\')")\n            self._conn.execute("CREATE TABLE IF NOT EXISTS pages (url TEXT PRIMARY KEY, title TEXT, body TEXT, origin_url TEXT, depth INTEGER)")\n            self._conn.execute("CREATE TABLE IF NOT EXISTS settings (key TEXT PRIMARY KEY, value TEXT)")\n\n    async def add_to_queue(self, urls: List[str], depth: int) -> None:\n        async with self._lock:\n            def _sync():\n                data = [(url, depth, \'pending\') for url in urls]\n                self._conn.executemany("INSERT OR IGNORE INTO queue (url, depth, state) VALUES (?, ?, ?)", data)\n                self._conn.commit()\n            await asyncio.to_thread(_sync)\n\n    async def get_pending(self, limit: int) -> List[Tuple[str, int]]:\n        def _sync():\n            rows = self._conn.execute("SELECT url, depth FROM queue WHERE state = \'pending\' LIMIT ?", (limit,)).fetchall()\n            return [(r[\'url\'], r[\'depth\']) for r in rows]\n        return await asyncio.to_thread(_sync)\n\n    async def mark_processing(self, url: str) -> None:\n        async with self._lock:\n            await asyncio.to_thread(lambda: self._conn.execute("UPDATE queue SET state = \'processing\' WHERE url = ?", (url,)))\n            self._conn.commit()\n\n    async def mark_done(self, url: str) -> None:\n        async with self._lock:\n            await asyncio.to_thread(lambda: self._conn.execute("UPDATE queue SET state = \'done\' WHERE url = ?", (url,)))\n            self._conn.commit()\n\n    async def save_page(self, url: str, title: str, body: str, origin_url: str, depth: int) -> None:\n        async with self._lock:\n            await asyncio.to_thread(lambda: self._conn.execute("INSERT OR REPLACE INTO pages (url, title, body, origin_url, depth) VALUES (?, ?, ?, ?, ?)", (url, title, body, origin_url, depth)))\n            self._conn.commit()\n\n    async def resume_processing(self) -> None:\n        async with self._lock:\n            await asyncio.to_thread(lambda: self._conn.execute("UPDATE queue SET state = \'pending\' WHERE state = \'processing\'"))\n            self._conn.commit()\n\n    async def get_status(self) -> Dict[str, int]:\n        def _sync():\n            rows = self._conn.execute("SELECT state, COUNT(*) as count FROM queue GROUP BY state").fetchall()\n            return {row[\'state\']: row[\'count\'] for row in rows}\n        return await asyncio.to_thread(_sync)\n\n    async def search(self, query: str) -> List[dict]:\n        def _sync():\n            sql = "SELECT url, title, depth, origin_url FROM pages WHERE title LIKE ? OR body LIKE ?"\n            q = f"%{query}%"\n            rows = self._conn.execute(sql, (q, q)).fetchall()\n            return [dict(r) for r in rows]\n        return await asyncio.to_thread(_sync)\n\n    async def get_setting(self, key: str) -> Optional[str]:\n        def _sync():\n            row = self._conn.execute("SELECT value FROM settings WHERE key = ?", (key,)).fetchone()\n            return row[\'value\'] if row else None\n        return await asyncio.to_thread(_sync)\n\n    async def set_setting(self, key: str, value: str) -> None:\n        async with self._lock:\n            await asyncio.to_thread(lambda: self._conn.execute("INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)", (key, value)))\n            self._conn.commit()\n\n    async def close(self) -> None:\n        await asyncio.to_thread(self._conn.close)\n```\n\nFILE: main.py\n```python\nimport asyncio\nimport sys\nfrom database import Database\nfrom crawler_service import CrawlerService\nfrom rich.console import Console\nfrom rich.table import Table\n\nconsole = Console(force_terminal=True, ascii_only=True)\n\nasync def main():\n    db = Database(\'crawler.db\')\n    service = CrawlerService(db)\n\n    console.print("[bold]Mini Search Engine CLI[/bold]")\n    console.print("Commands: crawl <url> <depth>, search <query>, status, resume, exit")\n\n    while True:\n        try:\n            cmd_input = await asyncio.to_thread(input, "> ")\n            parts = cmd_input.strip().split()\n            if not parts: continue\n            cmd = parts[0].lower()\n\n            if cmd == "crawl":\n                if len(parts) < 3:\n                    console.print("Usage: crawl <url> <depth>")\n                    continue\n                url, depth = parts[1], int(parts[2])\n                await db.set_setting(\'max_depth\', str(depth))\n                await db.add_to_queue([url], 0)\n                service.start_in_background(depth)\n           